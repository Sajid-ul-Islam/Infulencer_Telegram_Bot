# ============ SETUP GUIDE ============

# 1. GET YOUR TELEGRAM TOKEN
#    - Open Telegram and chat with @BotFather
#    - Type: /newbot
#    - Follow instructions to create bot
#    - Copy the token (looks like: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11)

# 2. GET YOUR CHANNEL ID
#    Option A (Easy):
#    - Add your bot to your channel as admin
#    - Send a message in channel
#    - Go to: https://api.telegram.org/bot[YOUR_TOKEN]/getUpdates
#    - Look for "chat": {"id": -100123456789}
#    - Use that number (with minus sign)
#    
#    Option B (Via Bot):
#    - Forward a channel message to @userinfobot
#    - It will show your channel ID

# 3. GET YOUTUBE CHANNEL ID
#    - Go to: https://www.youtube.com/@yourhandle
#    - Right-click → View page source
#    - Search for: "externalId":"UCxxxxxxxxxxxxxx"
#    - Or use: https://www.youtube.com/c/YOUR_CHANNEL/about
#    - Copy the ID from URL

# 4. CREATE .env FILE
#    Copy this file to .env and fill in your values

# ============ ENVIRONMENT VARIABLES ============

TELEGRAM_TOKEN=your_bot_token_here
CHANNEL_ID=-100123456789
GROUP_ID=-100987654321

# AI API Keys
OPENROUTER_API_KEY=your_openrouter_key
GROQ_API_KEY=your_groq_key
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
XAI_API_KEY=your_xai_key
GEMINI_API_KEY=your_gemini_key

# Optional: Set to your timezone (default: UTC)
TIMEZONE=Asia/Dhaka


# Content Platform Settings
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxx
MEDIUM_USERNAME=your_username
INSTAGRAM_HANDLE=@your_handle

# Social Links
YOUTUBE_LINK=https://www.youtube.com/@your_channel
MEDIUM_LINK=https://medium.com/@your_username
SUBSTACK_URL=https://your-username.substack.com
INSTAGRAM_LINK=https://instagram.com/your_handle
TWITTER_LINK=https://x.com/your_handle
FACEBOOK_LINK=https://facebook.com/your_page
