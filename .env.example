# ============================================================
# Bearded Bangali Telegram Bot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# On Render, set these as Environment Variables in the dashboard.
# ============================================================

# --- Telegram ---
# Required: Get from @BotFather on Telegram
TELEGRAM_TOKEN=

# Required: Your Telegram channel ID (starts with -100, e.g. -100123456789)
CHANNEL_ID=

# Optional: Your Telegram group ID (enables moderation features)
GROUP_ID=

# Optional: Your Telegram user ID (enables admin commands)
ADMIN_ID=

# --- Firebase / Firestore ---
# Required: Firebase service account JSON (single line, no newlines)
# Get from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_CREDENTIALS=

# --- AI Providers (at least one required) ---
# Primary: Full agent with tools (recommended)
OPENROUTER_API_KEY=

# Fallback: Fast inference + Whisper voice transcription
GROQ_API_KEY=

# Fallback: Direct OpenAI API (full agent with tools)
OPENAI_API_KEY=

# Fallback: Cost-effective reasoning (no function calling)
DEEPSEEK_API_KEY=

# Fallback: Anthropic Claude
ANTHROPIC_API_KEY=

# Fallback: xAI Grok-3
XAI_API_KEY=

# Fallback: Google Gemini 2.0
GEMINI_API_KEY=

# Optional: Local Ollama server (final fallback)
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2:3b

# --- Content Platforms ---
YOUTUBE_CHANNEL_ID=UCdFRSOdsaGPThmEsZb1tjXw
YOUTUBE_LINK=https://www.youtube.com/@bearded_bangali
MEDIUM_USERNAME=b3ngali
MEDIUM_LINK=https://medium.com/@b3ngali
SUBSTACK_URL=https://b3ngali.substack.com
INSTAGRAM_HANDLE=@bearded_bangali
INSTAGRAM_LINK=https://instagram.com/bearded_bangali
TWITTER_LINK=https://x.com/Beraded_Bengali
FACEBOOK_LINK=https://facebook.com/bb3ngali
# Optional: RSS URL generated from tools like RSS.app or FetchRSS for Facebook page
FACEBOOK_RSS_URL=

# --- Dashboard & Webhook ---
DASHBOARD_PASSWORD=admin
RENDER_EXTERNAL_URL=
WEBHOOK_URL=

# --- Meta (WhatsApp / Messenger / Instagram) ---
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=my_secret_verify_token

# --- Rate Limits ---
RATE_LIMIT_DAILY=50
RATE_LIMIT_VOICE_DAILY=20
INLINE_MAX_RESULTS=10

# --- Timezone ---
TIMEZONE=UTC
